---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';

const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID ?? '';
const action = formspreeId
  ? `https://formspree.io/f/${formspreeId}`
  : 'mailto:ngcesare@gmail.com';
const method = formspreeId ? 'POST' : 'GET';
---
<BaseLayout
  title="Contact — Cesare Scalia"
  description="Get in touch with Cesare Scalia."
>
  <h1 class="text-3xl font-serif font-semibold tracking-tight">Contact</h1>
  <p class="mt-3 text-slate-700 dark:text-slate-300">
    The fastest way to reach me is via the form below.
  </p>

  <form
    action={action}
    method={method}
    class="mt-8 space-y-5"
  >
    <div>
      <label for="name" class="block text-sm font-medium text-slate-700 dark:text-slate-300">
        Name
      </label>
      <input
        id="name"
        name="name"
        type="text"
        required
        autocomplete="name"
        class="mt-1 w-full rounded-md border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 px-3 py-2 text-sm text-slate-900 dark:text-slate-100 focus:border-accent-500 focus:outline-none focus:ring-2 focus:ring-accent-500/30"
      />
    </div>

    <div>
      <label for="email" class="block text-sm font-medium text-slate-700 dark:text-slate-300">
        Email
      </label>
      <input
        id="email"
        name="email"
        type="email"
        required
        autocomplete="email"
        class="mt-1 w-full rounded-md border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 px-3 py-2 text-sm text-slate-900 dark:text-slate-100 focus:border-accent-500 focus:outline-none focus:ring-2 focus:ring-accent-500/30"
      />
    </div>

    <div>
      <label for="message" class="block text-sm font-medium text-slate-700 dark:text-slate-300">
        Message
      </label>
      <textarea
        id="message"
        name="message"
        rows="6"
        required
        class="mt-1 w-full rounded-md border border-slate-300 dark:border-slate-700 bg-white dark:bg-slate-900 px-3 py-2 text-sm text-slate-900 dark:text-slate-100 focus:border-accent-500 focus:outline-none focus:ring-2 focus:ring-accent-500/30"
      ></textarea>
    </div>

    <!-- Honeypot: real humans should leave this empty. -->
    <div class="hidden" aria-hidden="true">
      <label for="website">Website</label>
      <input id="website" type="text" name="_gotcha" tabindex="-1" autocomplete="off" />
    </div>

    <button
      type="submit"
      class="inline-flex items-center rounded-md bg-accent-700 px-4 py-2 text-sm font-medium text-white hover:bg-accent-600"
    >
      Send
    </button>
  </form>

  <p class="mt-6 text-sm text-slate-600 dark:text-slate-400">
    or email
    <a href="mailto:ngcesare@gmail.com" class="text-accent-700 dark:text-accent-400">ngcesare@gmail.com</a>
    directly.
  </p>

  <div class="mt-10">
    <h2 class="text-lg font-serif font-semibold tracking-tight mb-3">Elsewhere</h2>
    <SocialLinks />
  </div>
</BaseLayout>
