---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const bp = import.meta.env.BASE_URL;
const base = bp.endsWith('/') ? bp.slice(0, -1) : bp;

// Eagerly import all volunteering cover assets
const coverAssets = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/volunteering/*.{svg,jpg,jpeg,png,webp,gif}',
  { eager: true },
);
const coverByName = new Map<string, ImageMetadata>(
  Object.entries(coverAssets).map(([path, mod]) => [
    path.split('/').pop()!,
    mod.default,
  ]),
);

const entries = await getCollection('volunteering');
const items = await Promise.all(
  entries.map(async (entry) => {
    const { Content } = await render(entry);
    const coverName = entry.data.coverImage;
    const cover = coverName ? coverByName.get(coverName) : undefined;
    return { entry, Content, cover };
  }),
);

// Sort: ongoing first (period contains "present"), then by period desc
items.sort((a, b) => {
  const aOngoing = a.entry.data.period.includes('present');
  const bOngoing = b.entry.data.period.includes('present');
  if (aOngoing && !bOngoing) return -1;
  if (!aOngoing && bOngoing) return 1;
  return b.entry.data.period.localeCompare(a.entry.data.period);
});
---
<BaseLayout
  title="Volunteering — Cesare Scalia"
  description="Social impact and volunteer activities: Corsie a Colori and Drugs & Help for Lebanon."
>
  <h1 class="text-3xl font-serif font-semibold tracking-tight mb-2">Volunteering</h1>
  <p class="text-slate-600 dark:text-slate-400 mb-10">
    Outside of research and industry work, I try to put energy into projects that matter beyond the lab or office.
  </p>

  <div class="space-y-16">
    {items.map(({ entry, Content, cover }) => (
      <article class="group">
        {cover && (
          <div class="mb-6 overflow-hidden rounded-xl border border-slate-200 dark:border-slate-800 aspect-[21/9] w-full bg-slate-100 dark:bg-slate-900">
            <img
              src={(cover as any).src ?? cover}
              alt={entry.data.title}
              loading="lazy"
              class="h-full w-full object-cover"
            />
          </div>
        )}

        <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1 mb-1">
          <h2 class="text-2xl font-serif font-semibold text-slate-900 dark:text-slate-100">
            {entry.data.title}
          </h2>
          <span class="text-sm text-slate-500 dark:text-slate-400 tabular-nums">
            {entry.data.period}
          </span>
        </div>

        {entry.data.subtitle && (
          <p class="text-base text-accent-700 dark:text-accent-400 font-medium mb-1">
            {entry.data.subtitle}
          </p>
        )}

        <div class="flex flex-wrap gap-x-4 gap-y-0.5 text-sm text-slate-500 dark:text-slate-400 mb-5">
          <span>{entry.data.role}</span>
          {entry.data.location && (
            <>
              <span aria-hidden="true">·</span>
              <span>{entry.data.location}</span>
            </>
          )}
        </div>

        <div class="prose prose-slate dark:prose-invert max-w-none prose-p:leading-relaxed prose-a:text-accent-700 dark:prose-a:text-accent-400">
          <Content />
        </div>

        {entry.data.links.length > 0 && (
          <ul class="mt-5 flex flex-wrap gap-3">
            {entry.data.links.map((link) => (
              <li>
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 rounded-full border border-accent-300 dark:border-accent-700 px-4 py-1.5 text-sm text-accent-700 dark:text-accent-400 hover:bg-accent-50 dark:hover:bg-accent-900/30 transition-colors no-underline"
                >
                  {link.label} ↗
                </a>
              </li>
            ))}
          </ul>
        )}

        <hr class="mt-14 border-slate-100 dark:border-slate-800 last:hidden" />
      </article>
    ))}
  </div>
</BaseLayout>
