---
interface Props {
  title: string;
  year: number;
  venue: string;
  venueShort?: string;
  type: "peer-reviewed" | "conference" | "internal-talk" | "poster";
  authors: string[];
  authorPosition: "first" | "middle" | "last" | "solo";
  doi?: string | null;
  adsLink?: string | null;
  url?: string | null;
}

const {
  title,
  year,
  venue,
  venueShort,
  type,
  authors,
  doi,
  adsLink,
  url,
} = Astro.props;

const isJournalArticle = type === "peer-reviewed";
const venueLabel = venueShort ?? venue;
const authorsLabel = authors.join(", ");
const doiHref = doi ? (doi.startsWith("http") ? doi : `https://doi.org/${doi}`) : null;
---
<li
  class="group grid grid-cols-[3rem_1fr_auto] items-baseline gap-x-4 gap-y-1 py-3 border-b border-slate-100 dark:border-slate-800 last:border-b-0"
  data-type={type}
  data-year={year}
>
  <span
    class="font-mono text-xs tabular-nums text-slate-500 dark:text-slate-400 pt-0.5"
    aria-label={`Year ${year}`}
  >
    {year}
  </span>

  <div class="min-w-0">
    <h3
      class:list={[
        "text-sm text-slate-900 dark:text-slate-100 font-serif leading-snug",
        isJournalArticle && "italic",
      ]}
    >
      {title}
    </h3>
    <p class="mt-1 text-xs text-slate-600 dark:text-slate-400 leading-relaxed">
      {authorsLabel}
    </p>
    {(doiHref || adsLink || url) && (
      <p class="mt-1 flex flex-wrap gap-x-3 gap-y-1 text-xs">
        {doiHref && (
          <a
            href={doiHref}
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent-700 dark:text-accent-400 no-underline hover:underline"
            aria-label={`DOI link for ${title}`}
          >
            DOI &#8599;
          </a>
        )}
        {adsLink && (
          <a
            href={adsLink}
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent-700 dark:text-accent-400 no-underline hover:underline"
            aria-label={`ADS link for ${title}`}
          >
            ADS &#8599;
          </a>
        )}
        {url && (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent-700 dark:text-accent-400 no-underline hover:underline"
          >
            Link &#8599;
          </a>
        )}
      </p>
    )}
  </div>

  <span
    class="justify-self-end text-xs font-medium text-slate-600 dark:text-slate-400 whitespace-nowrap pt-0.5"
    title={venue}
  >
    {venueLabel}
  </span>
</li>
