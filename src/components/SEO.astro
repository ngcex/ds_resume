---
// Expanded SEO component — handles <title>, meta, OG, Twitter, JSON-LD.
interface ArticleMeta {
  publishDate?: string | Date;
  modifiedDate?: string | Date;
  author?: string;
}

interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article' | 'profile';
  article?: ArticleMeta;
  schema?: 'Person' | 'WebSite' | 'CollectionPage' | null;
}

const {
  title,
  description,
  canonical,
  image,
  type = 'website',
  article,
  schema = null,
} = Astro.props;

const bp = import.meta.env.BASE_URL;
const baseTrim = bp.endsWith('/') ? bp.slice(0, -1) : bp;
const siteOrigin = Astro.site?.toString().replace(/\/$/, '') ?? 'https://ngcex.github.io';

// Canonical URL: prefer prop, else build from Astro.site + pathname.
const canonicalUrl =
  canonical ??
  (Astro.site
    ? new URL(Astro.url.pathname, Astro.site).toString()
    : `${siteOrigin}${Astro.url.pathname}`);

// OG image: default to /og-image.png under base.
const defaultOg = `${siteOrigin}${baseTrim}/og-image.png`;
const ogImage = image ?? defaultOg;

// Title assembly: "{title} — Cesare Scalia, PhD" unless title is already the
// home/root full title.
const homeTitle = 'Cesare Scalia, PhD — Lead Data Scientist';
const pathname = Astro.url.pathname.replace(/\/$/, '');
const basePath = baseTrim.replace(/^\//, '');
const isHome =
  pathname === '' ||
  pathname === '/' ||
  pathname === baseTrim ||
  pathname === `/${basePath}` ||
  pathname === `/${basePath}/index`;
const fullTitle = isHome ? homeTitle : `${title} — Cesare Scalia, PhD`;

const siteName = 'Cesare Scalia, PhD';

// JSON-LD schema blocks.
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Cesare Scalia',
  honorificSuffix: 'PhD',
  jobTitle: 'Lead Data Scientist',
  worksFor: { '@type': 'Organization', name: 'Life360' },
  alumniOf: [
    { '@type': 'CollegeOrUniversity', name: 'University of Catania' },
    { '@type': 'Organization', name: 'Armagh Observatory' },
  ],
  url: 'https://ngcex.github.io/ds_resume',
  sameAs: [
    'https://github.com/ngcex',
    'https://www.linkedin.com/in/cesare-scalia-phd/',
    'https://orcid.org/0000-0002-8399-6549',
  ],
  identifier: {
    '@type': 'PropertyValue',
    propertyID: 'ORCID',
    value: '0000-0002-8399-6549',
  },
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteName,
  url: 'https://ngcex.github.io/ds_resume',
  description,
  author: {
    '@type': 'Person',
    name: 'Cesare Scalia',
  },
  inLanguage: 'en-US',
};

const collectionPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  url: canonicalUrl,
  isPartOf: {
    '@type': 'WebSite',
    name: siteName,
    url: 'https://ngcex.github.io/ds_resume',
  },
};

let schemaJson: Record<string, unknown> | null = null;
if (schema === 'Person') schemaJson = personSchema;
else if (schema === 'WebSite') schemaJson = websiteSchema;
else if (schema === 'CollectionPage') schemaJson = collectionPageSchema;

const pub = article?.publishDate
  ? article.publishDate instanceof Date
    ? article.publishDate.toISOString()
    : new Date(article.publishDate).toISOString()
  : null;
const mod = article?.modifiedDate
  ? article.modifiedDate instanceof Date
    ? article.modifiedDate.toISOString()
    : new Date(article.modifiedDate).toISOString()
  : null;
---
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="author" content="Cesare Scalia" />
<link rel="canonical" href={canonicalUrl} />

<meta property="og:site_name" content={siteName} />
<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="en_US" />

{type === 'article' && pub && <meta property="article:published_time" content={pub} />}
{type === 'article' && mod && <meta property="article:modified_time" content={mod} />}
{type === 'article' && article?.author && (
  <meta property="article:author" content={article.author} />
)}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

{schemaJson && (
  <script type="application/ld+json" set:html={JSON.stringify(schemaJson)} />
)}